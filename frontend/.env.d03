# Caltrans D03 (Sacramento 2023) Frontend Configuration
# 743 sensors, HeteroDiffusionGraphForecaster + WeatherCorrectionNet

# API Backend URL
VITE_API_BASE=http://127.0.0.1:8010

# Polling interval (milliseconds)
# Development: 3000ms (3s)
# Production: 300000ms (5min)
VITE_POLL_MS=3000

# Dataset Information
# Dataset: Caltrans D03 Sacramento 2023
# Sensors: 743
# Time Range: 2023-01-01 to 2023-12-31
# Temporal Resolution: 5 minutes
# Features: flow, occupancy, speed + weather + accidents
